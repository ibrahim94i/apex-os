# ============================================================
# APEX OS v2.0 — Windows Native (no Docker)
# Copy this file to .env on Desktop
# ============================================================

DATABASE_URL=postgresql+asyncpg://apex:apex@localhost:5432/apexdb
REDIS_URL=redis://localhost:6379/0
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@kline_1h
# Dashboard-only live ticker for XAUUSD (Binance futures XAUUSDT — display only)
BINANCE_DISPLAY_TICKER_WS_URL=wss://fstream.binance.com/ws/xauusdt@markPrice@1s
BINANCE_DISPLAY_TICKER_REST_URL=https://fapi.binance.com/fapi/v1/ticker/price?symbol=XAUUSDT
TWELVEDATA_API_KEY=your_key_here
# XAUUSD, EURUSD, USDJPY, GBPUSD use TwelveData (same TWELVEDATA_API_KEY).
# XAUUSD polls every 60s; EURUSD/USDJPY/GBPUSD every 300s (TwelveData credits).
ALPHAVANTAGE_API_KEY=your_key_here
# Alpha Vantage NEWS_SENTIMENT (used by news agent alongside Finnhub + RSS)
TWELVEDATA_SYMBOL=XAU/USD
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
ENVIRONMENT=development
ADMIN_API_KEY=your_admin_key_here
LOG_LEVEL=INFO
ACCOUNT_BALANCE=10000.0
SIGNAL_TIMEFRAME=1h
MIN_SIGNAL_CONFIDENCE_PCT=70
MIN_SIGNAL_CONFIDENCE_PCT_POST_LEARNING=80
HIGH_SELECTIVITY_LEARNING_START=2026-05-29
LEARNING_PERIOD_DAYS=14
SIGNAL_COOLDOWN_HOURS=2
XAUUSD_MIN_PRICE_MOVE=0.50
MAX_RISK_PER_TRADE_PCT=1.0
MIN_RISK_REWARD_RATIO=2.0
MAX_DRAWDOWN_PCT=5.0
MAX_DAILY_LOSS_PCT=2.0
MAX_CONSECUTIVE_LOSSES=3
FEED_STALENESS_LIMIT_SECONDS=300
NEWS_BLOCK_WINDOW_MINUTES=30
FRONTEND_URL=http://localhost:3000
OPENAI_API_KEY=your_key_here
GROQ_API_KEY=your_key_here
FINNHUB_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PRIMARY_PROVIDER=groq
AGENT_DATA_MAX_AGE_SECONDS=300
SIGNAL_EMISSION_INTERVAL_HOURS=1
AGENT_TIMEOUT_SECONDS=30
AGENT_MAX_RETRIES=2
AGENT_CIRCUIT_BREAKER_THRESHOLD=3

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# PostgreSQL Windows paths (edit if installed elsewhere)
PGSERVICE=postgresql-x64-18
PG_BIN=C:\Program Files\PostgreSQL\18\bin
PG_USER=postgres
PG_PASSWORD=

# Redis Windows service name
REDIS_SERVICE=Redis
